# Copy to .env for local dev. Never commit the real .env (it's gitignored).
# All of this is also how you'd set Railway environment variables in prod.

ENVIRONMENT=development

# Local dev default: file-based SQLite, zero setup. Point this at Railway
# Postgres in production (Railway injects DATABASE_URL automatically once
# you attach the Postgres plugin). For docker-compose, use:
# postgresql+psycopg://engine:engine@postgres:5432/trading_engine
DATABASE_URL=sqlite:///./local_dev.db

UNIVERSE_PATH=universe.yaml
DATA_DIR=data_snapshots

# --- Broker (Alpaca paper trading) ------------------------------------------
# Get these from a free Alpaca PAPER account: https://app.alpaca.markets
# (paper trading tab -- do not generate live keys for this project).
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Do NOT set ALPACA_BASE_URL or ALPACA_LIVE. Their mere presence trips the
# paper-only guard (engine/config/guard.py) and the service refuses to
# start. The paper endpoint is hardcoded in engine/execution/alpaca.py.

# `engine papertrade` reconciles/watches the kill switch either way; set
# these to also actually trade a strategy live (same Strategy object,
# RiskGate, and signals as `engine backtest`). One of: dumb_news,
# overnight_gap, momentum, mean_reversion, multi_factor. Leave
# PAPERTRADE_STRATEGY unset to run the reconcile-only skeleton with no
# trading. Switching strategies is just an env var change + redeploy, no
# code change needed.
PAPERTRADE_STRATEGY=
PAPERTRADE_INTERVAL=1h

# --- News (optional, beyond the free no-key RSS feeds) ----------------------
NEWS_API_KEY=
FINNHUB_API_KEY=

# Historical news backfill (engine.data.alpaca_news). Reuses ALPACA_API_KEY/
# ALPACA_API_SECRET above -- no separate signup. When set, `engine ingest`
# and `engine backtest` use Alpaca's News API (Benzinga-sourced, real dated
# articles back to 2015) instead of live-only RSS, so a backtest over any
# past date range gets real news for that range rather than only whatever
# `engine ingest` happened to be running when it was current. Falls back to
# RSS automatically if this is unset or auth fails.
#
# We can't know the real historical ingestion lag for backfilled articles
# (we weren't polling back then), so one is simulated: published_at + this
# many seconds. Deliberately pessimistic (nonzero), not a guess at zero-lag
# -- see docs/bias_review.md and engine/data/alpaca_news.py.
ALPACA_NEWS_BACKFILL_LAG_SECONDS=900.0

# --- Consequence-prediction pipeline (engine.prediction, `engine predict-news`) ---
# Get a key from https://console.anthropic.com. Without it, `predict-news`
# refuses to run rather than silently doing nothing.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# REQUIRED, and NOT a value to guess: the actual training-data knowledge
# cutoff date for whichever model ANTHROPIC_MODEL names. This is the field
# that makes forward-testing honest -- a prediction about an event before
# this date could just be the model recalling what already happened, not a
# genuine forecast. Look up the real cutoff for your model before setting
# this; the placeholder below deliberately makes the pipeline refuse to run
# until you do. See engine/prediction/client.py.
ANTHROPIC_MODEL_KNOWLEDGE_CUTOFF=1970-01-01
PREDICTION_RESOLUTION_HOURS=24.0
PREDICTION_RETRIEVAL_LIMIT=5
# Minimum confidence before `engine act-on-predictions` submits a real
# paper order for a prediction; below this, it's still logged and scored,
# just never traded. See engine/prediction/trading.py.
PREDICTION_ACTION_CONFIDENCE_THRESHOLD=0.6
# Cycle interval for `engine predict-loop` -- the automatic, always-on
# version of predict-news + act-on-predictions + resolve-predictions.
PREDICTION_LOOP_POLL_SECONDS=3600

# --- Alerting (optional) -----------------------------------------------------
# Any Discord/Slack/Telegram-compatible webhook URL that accepts
# {"content": "..."} as JSON.
ALERT_WEBHOOK_URL=

# --- Remote kill switch -------------------------------------------------------
# Set to true and redeploy/restart to flatten everything and halt trading.
HALT=false
HALT_FILE=HALT

RANDOM_SEED=1337
LOG_LEVEL=INFO
LOG_JSON=true

# --- Risk limits (defaults shown; override only with a clear reason) --------
RISK_MAX_CAPITAL_PER_POSITION_PCT=0.05
RISK_MAX_TOTAL_EXPOSURE_PCT=0.20
RISK_STOP_LOSS_PCT=0.02
RISK_MAX_DAILY_DRAWDOWN_PCT=0.03
RISK_MAX_CONSECUTIVE_LOSSES_PER_DAY=4
RISK_ALLOW_OVERNIGHT_POSITIONS=false
